{
  "name": "trayofree",
  "version": "1.0.0",
  "description": "Sistema de Gestão para Restaurantes",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.trayofree.sistema",
    "productName": "TrayoFREE",
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "TrayoFREE",
      "createDesktopShortcut": true
    },
    "files": [
      "**/*",
      "!dist/*"
    ]
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "^26.8.1"
  }
}
